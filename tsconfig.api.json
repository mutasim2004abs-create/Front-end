{
  "compilerOptions": {
    "target": "ES2022",
    // DOM is here for the Web-standard Request/Response/Headers the handler uses —
    // Vercel's Node runtime exposes them as globals.
    "lib": ["ES2023", "DOM"],
    // NodeNext matches the runtime (Node ESM) and the explicit .js import specifiers.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node", "vitest/globals"],

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["api"]
}
